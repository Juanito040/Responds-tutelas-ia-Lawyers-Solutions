# ─── BASE DE DATOS ───────────────────────────────────────────────────────────
# Pooler Supabase — para la app (con pgbouncer)
DATABASE_URL="postgresql://postgres.[project-ref]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexión directa — solo para migraciones (prisma migrate dev)
DIRECT_URL="postgresql://postgres.[project-ref]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# ─── NEXTAUTH ────────────────────────────────────────────────────────────────
# URL base de la aplicación
NEXTAUTH_URL="http://localhost:3000"
# Secret aleatorio y seguro — generar con: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ─── GEMINI AI ───────────────────────────────────────────────────────────────
# Obtener en: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=""

# ─── GROQ AI ─────────────────────────────────────────────────────────────────
# Obtener en: https://console.groq.com → API Keys
GROQ_API_KEY=""

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
