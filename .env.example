# ─── BASE DE DATOS ───────────────────────────────────────────────────────────
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/tutela_ia?schema=public"

# ─── NEXTAUTH ────────────────────────────────────────────────────────────────
# URL base de la aplicación
NEXTAUTH_URL="http://localhost:3000"
# Secret aleatorio y seguro — generar con: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ─── GEMINI AI ───────────────────────────────────────────────────────────────
# Obtener en: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=""

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
