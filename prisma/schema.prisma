// Prisma Schema — TutelaIA
// db-testing skill: índices en FK y búsquedas, soft delete, campos audit

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USUARIOS ────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?   // hash bcrypt — nunca texto plano
  role          Role      @default(ABOGADO)
  image         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  casos     Caso[]

  @@index([email])
  @@map("users")
}

enum Role {
  ABOGADO
  ASISTENTE
  ADMIN
}

// ─── NEXTAUTH ────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── CASOS (TUTELAS) ─────────────────────────────────────────────────────────

model Caso {
  id     String @id @default(cuid())
  userId String

  // Partes del proceso
  accionante String
  accionado  String

  // Contenido jurídico
  hechos            String     @db.Text
  derechosInvocados String     @db.Text
  tipoTutela        TipoTutela @default(OTRO)

  // Datos del juzgado
  juez     String?
  juzgado  String?
  radicado String?

  // Fechas y plazos
  fechaNotificacion DateTime
  fechaLimite       DateTime // calculado: 10 días hábiles
  diasRestantes     Int?

  // Auto del juzgado (texto extraído del PDF del auto admisorio)
  autoJuzgado     String?  @db.Text
  autoJuzgadoNombre String? // nombre del archivo original

  // Estado
  estado   EstadoCaso @default(PENDIENTE)
  isActive Boolean    @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  contestacion Contestacion?

  @@index([userId])
  @@index([estado])
  @@index([fechaLimite])
  @@index([userId, estado])
  @@map("casos")
}

enum TipoTutela {
  SALUD
  TRABAJO
  EDUCACION
  PENSION
  VIVIENDA
  DEBIDO_PROCESO
  INTIMIDAD
  IGUALDAD
  OTRO
}

enum EstadoCaso {
  PENDIENTE
  EN_PROCESO
  CONTESTADA
  VENCIDA
}

// ─── CONTESTACIONES ──────────────────────────────────────────────────────────

model Contestacion {
  id       String @id @default(cuid())
  casoId   String @unique

  contenido     String  @db.Text
  version       Int     @default(1)
  generadoPorIA Boolean @default(true)
  modeloIA      String?
  tokensUsados  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  caso Caso @relation(fields: [casoId], references: [id], onDelete: Cascade)

  @@index([casoId])
  @@map("contestaciones")
}
